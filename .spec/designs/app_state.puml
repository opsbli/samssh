@startuml SamSSH AppState
!theme plain

entity "AppState" as APP_STATE {
  + sidebar: SidebarState
  + tabs: TabState
  + sessions: HashMap<SessionId, SessionState>
  + config: Arc<Config>
}

entity "SidebarState" as SIDEBAR {
  + groups: Vec<GroupNode>
  + expanded: HashSet<GroupId>
  + selected: Option<HostId>
  + quick_connect: String
}

entity "GroupNode" as GROUP {
  + id: GroupId
  + name: String
  + hosts: Vec<HostId>
  + expanded: bool
}

entity "TabState" as TABS {
  + tabs: Vec<TabItem>
  + active: Option<TabId>
  + next_id: TabId
}

entity "TabItem" as TAB_ITEM {
  + id: TabId
  + title: String
  + kind: SessionKind (Terminal | SFTP)
  + host_id: HostId
  + session_id: Option<SessionId>
}

entity "SessionState" as SESSION {
  + id: SessionId
  + host_id: HostId
  + kind: SessionKind (Terminal | SFTP)
  + status: ConnectionStatus
}

entity "Config" as CONFIG {
  + profiles: Vec<Profile>
  + settings: AppSettings
  + window_x/y/width/height: Option
  + window_maximized: bool
}

entity "Profile" as PROFILE {
  + id, name, host, port (22)
  + username, auth_method
  + group: Option
  + sort_order
  + password_encrypted: Option
}

entity "Workspace" as WORKSPACE {
  + app_state: Entity<AppState>
  + sidebar_tree: Entity<SidebarTree>
}

entity "SidebarTree" as SIDEBAR_TREE {
  + tree_state: Entity<TreeState>
  + app_state: Entity<AppState>
  右键菜单: Delete Host / Delete Group
}

entity "ProfileDialog" as DIALOG {
  trigger: "+" 按钮 (sidebar 顶部)
  fields: Name / Host / Port / Username / Group
  on_save: ConfigStore.save() + SidebarState.from_profiles()
}

APP_STATE --> SIDEBAR
APP_STATE --> TABS
APP_STATE --> SESSION : contains *
APP_STATE --> CONFIG
SIDEBAR --> GROUP : contains *
TABS --> TAB_ITEM : contains *
CONFIG --> PROFILE : contains *

WORKSPACE --> APP_STATE : holds Entity
WORKSPACE --> SIDEBAR_TREE : renders
WORKSPACE --> DIALOG : "+" button trigger

note right of APP_STATE : Entity<AppState>\n实际字段: sidebar, tabs, sessions, config
note right of WORKSPACE : 主视图，持有 AppState 引用
note right of DIALOG : R010 — 新建连接\n保存后自动刷新侧边栏
note right of SIDEBAR_TREE : R004 — 树组件\n已集成右键菜单

@enduml
