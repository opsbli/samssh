@startuml SamSSH Architecture
!theme plain

package "UI Layer (gpui-component)" as UI_LAYER {
' Source: https://github.com/longbridge/gpui-component
  [TitleBar] as TITLE_BAR
  [SidebarTree] as SIDEBAR
  [TabBar] as TAB_BAR
  [ProfileDialog] as DIALOG
  [TerminalView] as TERM_VIEW — TODO
  [FileManagerView] as FILE_VIEW — TODO
  [SettingsDialog] as SETTINGS — TODO
  [ThemeSelector] as THEME_SEL — TODO
}

package "State Management (Entity<AppState>)" {
  [AppState] as APP_STATE
  [ConfigStore] as CONFIG_STORE
  [Workspace] as WORKSPACE
}

package "Service Layer" {
  [SSHService] as SSH_SVC
  [SFTPClient] as SFTP_CLI
  [KeyVerifier] as KEY_VER
  [CryptoService] as CRYPTO
}

package "External" {
  [russh] as RUSSH
  [russh-sftp] as RUSSH_SFTP
  [wezterm-term] as TERM
  [Windows DPAPI] as DPAPI
  [tray-icon] as TRAY — TODO
}

' UI → Workspace → State
WORKSPACE --> APP_STATE : holds Entity<AppState>
TITLE_BAR --> WORKSPACE : render
SIDEBAR --> WORKSPACE : render + context menu
DIALOG --> WORKSPACE : + button trigger → save
TAB_BAR --> APP_STATE : read state

' State → Service
APP_STATE --> SSH_SVC : cx.spawn() →
APP_STATE --> SFTP_CLI : cx.spawn() →
APP_STATE --> CRYPTO : encrypt/decrypt

' Service → External
SSH_SVC --> RUSSH : russh::client
SFTP_CLI --> RUSSH_SFTP : russh_sftp::client
CRYPTO --> DPAPI : CryptProtectData

' Service → State (event queue)
SSH_SVC --> APP_STATE : message queue →
SFTP_CLI --> APP_STATE : message queue →

' Feature ↔ Requirement mapping
note right of SIDEBAR : R004 (TabBar & Sidebar) + R010 (右键菜单)
note right of DIALOG : R010 (新建连接对话框)
note right of WORKSPACE : R010 (主工作区视图)
note right of TERM_VIEW : R002 (Terminal) — TODO
note right of FILE_VIEW : R003 (SFTP) — TODO
note right of SETTINGS : R005 (Config) — TODO
note right of THEME_SEL : R006 (Theme) — TODO
note right of SSH_SVC : R001 (SSH), R008 (Security)
note right of CRYPTO : R008 (Crypto)
note right of TITLE_BAR : R009 (Window)

@enduml
